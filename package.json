{
  "name": "html-css-ai-learning-guide",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "vitepress dev docs",
    "generate:favicon": "node scripts/generate-favicon.mjs",
    "validate": "node scripts/validate-content.mjs",
    "validate:pages": "node scripts/validate-pages-build.mjs",
    "build": "npm run validate && vitepress build docs",
    "build:sites": "npm run build && node scripts/prepare-sites-build.mjs && node scripts/validate-sites-build.mjs",
    "preview": "node scripts/serve-static.mjs docs/.vitepress/dist"
  },
  "devDependencies": {
    "vitepress": "1.6.4",
    "vue": "3.5.40"
  }
}
